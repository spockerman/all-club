generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberCategory {
  TITULAR
  DEPENDENTE
  CONVIDADO
}

enum MemberStatus {
  ATIVO
  SUSPENSO
  INATIVO
  PENDENTE
}

enum BookingStatus {
  CONFIRMADO
  CANCELADO
  EXPIRADO
}

enum DayOfWeek {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
  DOMINGO
}

model Member {
  id        String         @id @default(uuid())
  name      String
  email     String         @unique
  phone     String?
  photoUrl  String?
  category  MemberCategory @default(TITULAR)
  status    MemberStatus   @default(PENDENTE)

  // Auto-relação: titular → dependentes
  holderId    String?
  holder      Member?  @relation("HolderDependents", fields: [holderId], references: [id])
  dependents  Member[] @relation("HolderDependents")

  bookings           Booking[]
  agendaReservations AgendaReservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([holderId])
  @@index([status])
}

model Area {
  id          String   @id @default(uuid())
  name        String
  description String?
  capacity    Int
  rules       String?
  active      Boolean  @default(true)

  availabilitySlots AvailabilitySlot[]
  blockedDates      BlockedDate[]
  bookings          Booking[]
  agendas           Agenda[]
  scheduleConfigs   ScheduleConfig[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AvailabilitySlot {
  id        String    @id @default(uuid())
  areaId    String
  area      Area      @relation(fields: [areaId], references: [id], onDelete: Cascade)
  dayOfWeek DayOfWeek
  startTime String    // HH:mm
  endTime   String    // HH:mm

  bookings  Booking[]

  @@unique([areaId, dayOfWeek, startTime])
  @@index([areaId])
}

model BlockedDate {
  id     String   @id @default(uuid())
  areaId String
  area   Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  date   DateTime @db.Date
  reason String?

  @@unique([areaId, date])
  @@index([areaId])
}

model Booking {
  id       String        @id @default(uuid())
  memberId String
  member   Member        @relation(fields: [memberId], references: [id])
  areaId   String
  area     Area          @relation(fields: [areaId], references: [id])
  slotId   String
  slot     AvailabilitySlot @relation(fields: [slotId], references: [id])
  date     DateTime      @db.Date
  status   BookingStatus @default(CONFIRMADO)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Evita duplo agendamento no mesmo slot/data
  @@unique([areaId, slotId, date, status])
  @@index([memberId])
  @@index([areaId, date])
}

// ── Agenda domain (English DDL) ───────────────────────────────────────────────

enum AgendaPeriod {
  MORNING
  AFTERNOON
  EVENING
  ALL_DAY
}

enum AgendaStatus {
  AVAILABLE
  RESERVED
  CANCELLED
}

enum ReservationStatus {
  CONFIRMED
  CANCELLED
}

enum TriggerType {
  AUTOMATIC
  MANUAL
}

enum ScheduleLogStatus {
  SUCCESS
  FAILURE
  PARTIAL
}

model Agenda {
  id        String       @id @default(uuid())
  areaId    String
  area      Area         @relation(fields: [areaId], references: [id])
  date      DateTime     @db.Date
  period    AgendaPeriod
  status    AgendaStatus @default(AVAILABLE)

  reservation AgendaReservation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([areaId, date, period])
  @@index([areaId, date])
  @@index([status])
  @@index([date])
}

model AgendaReservation {
  id           String            @id @default(uuid())
  agendaId     String            @unique
  agenda       Agenda            @relation(fields: [agendaId], references: [id])
  memberId     String
  member       Member            @relation(fields: [memberId], references: [id])
  status       ReservationStatus @default(CONFIRMED)
  cancelReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId])
}

model ScheduleConfig {
  id             String       @id @default(uuid())
  areaId         String
  area           Area         @relation(fields: [areaId], references: [id])
  cronExpression String
  period         AgendaPeriod
  daysAhead      Int          @default(7)
  description    String?
  active         Boolean      @default(true)

  logs ScheduleLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([areaId])
}

model ScheduleLog {
  id               String            @id @default(uuid())
  scheduleConfigId String
  config           ScheduleConfig    @relation(fields: [scheduleConfigId], references: [id])
  executedAt       DateTime          @default(now())
  triggerType      TriggerType
  status           ScheduleLogStatus
  agendasCreated   Int               @default(0)
  agendasSkipped   Int               @default(0)
  errorMessage     String?
  details          Json?

  @@index([scheduleConfigId])
  @@index([executedAt])
}
