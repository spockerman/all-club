generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberCategory {
  TITULAR
  DEPENDENTE
  CONVIDADO
}

enum MemberStatus {
  ATIVO
  SUSPENSO
  INATIVO
  PENDENTE
}

enum BookingStatus {
  CONFIRMADO
  CANCELADO
  EXPIRADO
}

enum DayOfWeek {
  SEGUNDA
  TERCA
  QUARTA
  QUINTA
  SEXTA
  SABADO
  DOMINGO
}

model Member {
  id               String         @id @default(uuid())
  name             String
  email            String         @unique
  phone            String?
  photoUrl         String?
  membershipNumber String?        @unique
  category         MemberCategory @default(TITULAR)
  status           MemberStatus   @default(PENDENTE)

  // Auto-relação: titular → dependentes
  holderId    String?
  holder      Member?  @relation("HolderDependents", fields: [holderId], references: [id])
  dependents  Member[] @relation("HolderDependents")

  bookings           Booking[]
  agendaReservations AgendaReservation[]
  user               User?
  otpCodes           MemberOtp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([holderId])
  @@index([status])
}

model Area {
  id          String   @id @default(uuid())
  name        String
  description String?
  capacity    Int
  rules       String?
  active      Boolean  @default(true)

  availabilitySlots AvailabilitySlot[]
  blockedDates      BlockedDate[]
  bookings          Booking[]
  agendas           Agenda[]
  scheduleConfigs   ScheduleConfig[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AvailabilitySlot {
  id        String    @id @default(uuid())
  areaId    String
  area      Area      @relation(fields: [areaId], references: [id], onDelete: Cascade)
  dayOfWeek DayOfWeek
  startTime String    // HH:mm
  endTime   String    // HH:mm

  bookings  Booking[]

  @@unique([areaId, dayOfWeek, startTime])
  @@index([areaId])
}

model BlockedDate {
  id     String   @id @default(uuid())
  areaId String
  area   Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  date   DateTime @db.Date
  reason String?

  @@unique([areaId, date])
  @@index([areaId])
}

model Booking {
  id       String        @id @default(uuid())
  memberId String
  member   Member        @relation(fields: [memberId], references: [id])
  areaId   String
  area     Area          @relation(fields: [areaId], references: [id])
  slotId   String
  slot     AvailabilitySlot @relation(fields: [slotId], references: [id])
  date     DateTime      @db.Date
  status   BookingStatus @default(CONFIRMADO)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Evita duplo agendamento no mesmo slot/data
  @@unique([areaId, slotId, date, status])
  @@index([memberId])
  @@index([areaId, date])
}

// ── Auth domain (English DDL) ────────────────────────────────────────────────

enum UserRole {
  ADMIN
  EMPLOYEE
  MEMBER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum AuditEvent {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  PASSWORD_CHANGED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  ACCOUNT_LOCKED
  ACCOUNT_UNLOCKED
  ACCOUNT_ACTIVATED
  ACCOUNT_DEACTIVATED
  TOKEN_REFRESHED
}

model User {
  id                  String     @id @default(uuid())
  email               String     @unique
  name                String
  phone               String?
  role                UserRole
  status              UserStatus @default(ACTIVE)
  memberId            String?    @unique

  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?

  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  member        Member?             @relation(fields: [memberId], references: [id])
  credential    UserCredential?
  profiles      UserAccessProfile[]
  refreshTokens RefreshToken[]
  auditLogs     SecurityAuditLog[]

  @@index([email])
  @@index([role])
  @@index([status])
}

model UserCredential {
  id                  String    @id @default(uuid())
  userId              String    @unique
  passwordHash        String
  passwordChangedAt   DateTime  @default(now())
  mustChangePassword  Boolean   @default(false)
  resetToken          String?   @unique
  resetTokenExpiresAt DateTime?
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AccessProfile {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  permissions AccessProfilePermission[]
  users       UserAccessProfile[]
}

model Permission {
  key         String @id
  description String
  resource    String

  profiles AccessProfilePermission[]

  @@index([resource])
}

model AccessProfilePermission {
  accessProfileId String
  permissionKey   String

  accessProfile AccessProfile @relation(fields: [accessProfileId], references: [id], onDelete: Cascade)
  permission    Permission    @relation(fields: [permissionKey], references: [key], onDelete: Cascade)

  @@id([accessProfileId, permissionKey])
}

model UserAccessProfile {
  userId          String
  accessProfileId String
  assignedAt      DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessProfile AccessProfile @relation(fields: [accessProfileId], references: [id], onDelete: Cascade)

  @@id([userId, accessProfileId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model SecurityAuditLog {
  id        String     @id @default(uuid())
  userId    String?
  event     AuditEvent
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime   @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([event])
  @@index([createdAt])
}

// ── Agenda domain (English DDL) ───────────────────────────────────────────────

enum AgendaPeriod {
  MORNING
  AFTERNOON
  EVENING
  ALL_DAY
}

enum AgendaStatus {
  AVAILABLE
  RESERVED
  CANCELLED
}

enum ReservationStatus {
  CONFIRMED
  CANCELLED
}

enum TriggerType {
  AUTOMATIC
  MANUAL
}

enum ScheduleLogStatus {
  SUCCESS
  FAILURE
  PARTIAL
}

model Agenda {
  id        String       @id @default(uuid())
  areaId    String
  area      Area         @relation(fields: [areaId], references: [id])
  date      DateTime     @db.Date
  period    AgendaPeriod
  status    AgendaStatus @default(AVAILABLE)

  reservation AgendaReservation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([areaId, date, period])
  @@index([areaId, date])
  @@index([status])
  @@index([date])
}

model AgendaReservation {
  id           String            @id @default(uuid())
  agendaId     String            @unique
  agenda       Agenda            @relation(fields: [agendaId], references: [id])
  memberId     String
  member       Member            @relation(fields: [memberId], references: [id])
  status       ReservationStatus @default(CONFIRMED)
  cancelReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId])
}

model ScheduleConfig {
  id             String       @id @default(uuid())
  areaId         String
  area           Area         @relation(fields: [areaId], references: [id])
  cronExpression String
  period         AgendaPeriod
  daysAhead      Int          @default(7)
  description    String?
  active         Boolean      @default(true)

  logs ScheduleLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([areaId])
}

// ── Marketing domain (English DDL) ───────────────────────────────────────────

enum MarketingMediaType {
  NOTICE
  MEDIA
}

model MarketingMedia {
  id        String             @id @default(uuid())
  title     String
  type      MarketingMediaType
  imageUrl  String             @db.Text
  active    Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([type])
  @@index([active])
}

// ── Club settings (key/value store) ─────────────────────────────────────────

model ClubSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model ScheduleLog {
  id               String            @id @default(uuid())
  scheduleConfigId String
  config           ScheduleConfig    @relation(fields: [scheduleConfigId], references: [id])
  executedAt       DateTime          @default(now())
  triggerType      TriggerType
  status           ScheduleLogStatus
  agendasCreated   Int               @default(0)
  agendasSkipped   Int               @default(0)
  errorMessage     String?
  details          Json?

  @@index([scheduleConfigId])
  @@index([executedAt])
}

// ── OTP domain ───────────────────────────────────────────────────────────────

model MemberOtp {
  id        String    @id @default(uuid())
  memberId  String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())

  member Member @relation(fields: [memberId], references: [id])

  @@index([memberId])
}
