{
  "expo": {
    "name": "All Club",
    "slug": "all-club",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1d4ed8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.allclub.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1d4ed8"
      },
      "package": "com.allclub.app"
    },
    "scheme": "all-club",
    "plugins": ["expo-router", "expo-secure-store"]
  }
}
